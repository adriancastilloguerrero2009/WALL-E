const char* password "password";

void setup() {
  Serial.begin(115200);
  WiFi.mode(WIFI_STA); // Set as Station Mode
  WiFi.begin(ssid, password);

  // Wait for connection
  while (WiFi.status() != WL_CONNECTED) {
    delay(500);
    Serial.print(".");
  }
  
  Serial.println("Connected to WiFi");
  Serial.println(WiFi.localIP()); // Print IP address
}
